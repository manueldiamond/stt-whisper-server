# Optional auth. Copy to .env on the server and set a private value.
# Never commit real secrets.
STT_API_TOKEN=

# Model/runtime overrides.
MODEL_SIZE=base
DEVICE=cpu
COMPUTE_TYPE=int8
LANGUAGE=en
BEAM_SIZE=1
VAD_FILTER=true
VAD_MIN_SILENCE_DURATION_MS=500
MAX_CONCURRENT_TRANSCRIPTIONS=3
MODEL_NUM_WORKERS=3
TMP_DIR=/dev/shm
LOG_LEVEL=INFO
