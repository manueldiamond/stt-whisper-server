# Optional auth. Copy to .env on the server and set a private value.
# Never commit real secrets.
STT_API_TOKEN=

# Dynamic model behavior.
# Client can send form field model=base/small/medium/turbo/etc.
# DEFAULT_MODEL is used if client sends no model.
MODEL_SIZE=base
DEFAULT_MODEL=base
PRELOAD_MODEL=
ALLOWED_MODELS=tiny,tiny.en,base,base.en,small,small.en,medium,medium.en,large-v1,large-v2,large-v3,large,distil-small.en,distil-medium.en,distil-large-v2,distil-large-v3,distil-large-v3.5,large-v3-turbo,turbo

# Runtime.
DEVICE=cpu
COMPUTE_TYPE=int8
LANGUAGE=en
BEAM_SIZE=1
VAD_FILTER=true
VAD_MIN_SILENCE_DURATION_MS=500
MAX_CONCURRENT_TRANSCRIPTIONS=3
MODEL_NUM_WORKERS=3
TMP_DIR=/dev/shm
LOG_LEVEL=INFO
